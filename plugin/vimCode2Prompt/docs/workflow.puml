@startuml vimCode2Prompt 整体流程
skinparam backgroundColor transparent
skinparam activity {
  BackgroundColor #2d2d2d
  BorderColor #61afef
  ArrowColor #abb2bf
  BorderThickness 1
}
skinparam diamond {
  BackgroundColor #2d2d2d
  BorderColor #61afef
  ArrowColor #abb2bf
}

start

:Vim 启动;

if (是否 Claude Code 自动检测?) then (是)
  :提取 @ 后路径部分;
  if (路径是否为空?) then (是 - 仅 @)
    :清空文件
    直接执行 :Code2Prompt;
    stop
  else (否)
    if (路径是否为目录?) then (是 - @dir/)
      :运行 code2prompt -c
      输出到剪贴板;
      :从剪贴板读取
      分割成行
      插入当前文件
      保存;
      stop
    else (否 - @file)
      if (文件是否存在可读?) then (是)
        :运行 code2prompt -c --include 文件
        输出到剪贴板;
        :从剪贴板读取
        分割成行
        插入当前文件
        保存;
        stop
      else (否)
        :提示错误
        保持原样;
        stop
      endif
    endif
  endif
else (否 - 手动启动)
  :用户执行 :Code2Prompt 命令;
  if (是否有可视区域选中?) then (是)
    :直接处理选中内容
    格式化 (添加文件路径+代码块);
    if (是否有源文件记录?) then (是 - 有记录)
      :追加回原始源文件
      清空记录;
      stop
    else (否)
      :复制到系统剪贴板;
      stop
    endif
  else (否)
    :检查依赖 (code2prompt + fzf);
    :确定起始路径
    调用 Code2PromptFzf;
    :fzf 文件选择界面打开;
    :用户按键选择;
    if (按键 == Enter?) then (Enter)
      :获取选中文件
      调用 ProcessSelectedFile;
      :运行 code2prompt -c
      输出复制到剪贴板;
      :从剪贴板读取实际内容;
      if (确定目标文件) then (有源文件记录)
        :追加到源文件末尾
        保存
        提示
        清空记录;
        stop
      else (无 - 当前就是目标)
        :追加到当前文件末尾
        保存
        提示
        清空记录;
        stop
      endif
    else (ctrl-t/ctrl-x/ctrl-v)
      :保存当前文件作为源文件
      记录 g:code2prompt_origin_file;
      :用对应动作在新标签/分割打开选中文件
      只读模式;
      :等待用户操作;
      :用户可视选择内容
      执行 :Code2Prompt;
      -> 跳转到 "是否有可视区域选中?"
    endif
  endif
endif

@enduml

@startuml Claude Code 自动检测启动流程
skinparam backgroundColor transparent
skinparam activity {
  BackgroundColor #2d2d2d
  BorderColor #61afef
  ArrowColor #abb2bf
  BorderThickness 1
}
skinparam diamond {
  BackgroundColor #2d2d2d
  BorderColor #61afef
  ArrowColor #abb2bf
}

start

:HandleClaudeCodeStartup
VimEnter ++once;

if (检查条件) then (不满足)
  : 1. 不只一个缓冲区\n 2. 不是一行\n 3. 不以 @ 开头\n 4. 文件只读;
  :直接返回，不处理;
  stop
else (满足所有条件)
endif

:提取 @ 之后 path_part
删除原行
清空文件
保存;

if (path_part 为空?) then (是 - @ 单独一行)
  :直接执行 :Code2Prompt;
  stop
else (否)
endif

:转换为绝对路径;

if (是目录?) then (是)
  :运行 code2prompt -c 目录
  输出到剪贴板;
else (否)
  if (文件可读?) then (是)
    :运行 code2prompt -c --include 文件
    输出到剪贴板;
  else (否)
    :提示路径不存在
    返回;
    stop
  endif
endif

if (执行成功?) then (是)
  :从剪贴板读取内容
  分割成行
  从第一行开始插入
  保存
  提示成功;
  stop
else (否)
  :提示执行失败
  返回;
  stop
endif

@enduml

@startuml ProcessSelectedFile 详细流程
skinparam backgroundColor transparent
skinparam activity {
  BackgroundColor #2d2d2d
  BorderColor #61afef
  ArrowColor #abb2bf
  BorderThickness 1
}
skinparam diamond {
  BackgroundColor #2d2d2d
  BorderColor #61afef
  ArrowColor #abb2bf
}

start

:ProcessSelectedFile(abs_path);

:检查文件是否可读;

if (文件不存在?) then (不存在)
  :提示错误
  返回;
  stop
else (存在)
endif

:构造 code2prompt 命令
code2prompt dir --include file -l --absolute-paths -c;

:执行命令
获取 stdout;

if (shell 错误?) then (是)
  :提示错误
  返回;
  stop
else (否)
endif

:从系统剪贴板读取实际内容
- macOS: pbpaste
- Linux: xclip
- 回退: getreg('*');

:确定目标源文件;

if (g:code2prompt_origin_file 存在可读?) then (是)
  :目标 = 记录的源文件;
else (否)
  :目标 = 当前缓冲区文件;
endif

if (目标有效 && 剪贴板非空?) then (否)
  :只保留剪贴板
  提示
  返回;
  stop
else (是)
endif

:分割剪贴板内容为行;

:切换到目标缓冲区
保存原视图;

:跳到文件末尾;

if (文件末尾不为空?) then (是)
  :先追加一个空行;
else (否)
  :文件为空，从第一行开始;
endif

:逐行追加到末尾;

:保存文件
恢复视图;

:提示成功
清空 g:code2prompt_origin_file;

stop

@enduml

@startuml fzf 按键处理流程
skinparam backgroundColor transparent
skinparam activity {
  BackgroundColor #2d2d2d
  BorderColor #61afef
  ArrowColor #abb2bf
  BorderThickness 1
}
skinparam diamond {
  BackgroundColor #2d2d2d
  BorderColor #61afef
  ArrowColor #abb2bf
}

start

:ProcessSelectedLines from fzf --expect;

:第一行 = 按下的按键;

if (按键为空?) then (是 - Enter)
  :获取第二行 = 选中文件
  ProcessSelectedFile;
  stop
else (否 - ctrl-t/ctrl-x/ctrl-v)
endif

:保存当前文件路径到 g:code2prompt_origin_file;

if (按键在动作映射中存在?) then (是)
  :用对应动作打开文件
  - ctrl-t → tab split
  - ctrl-x → split
  - ctrl-v → vsplit;
  if (多个文件?) then (是)
    :循环打开每个文件;
  endif
  stop
else (否)
  :按键当文件名处理
  ProcessSelectedFile;
  stop
endif

@enduml

@startuml 可视区域选择处理流程
skinparam backgroundColor transparent
skinparam activity {
  BackgroundColor #2d2d2d
  BorderColor #61afef
  ArrowColor #abb2bf
  BorderThickness 1
}
skinparam diamond {
  BackgroundColor #2d2d2d
  BorderColor #61afef
  ArrowColor #abb2bf
}

start

:Code2PromptProcessSelection
处理可视选中;

:获取选中行
检查非空;

if (选中为空?) then (是空)
  :提示错误
  返回;
  stop
else (非空)
endif

:格式化内容
添加文件头 + 代码块包裹;

if (g:code2prompt_origin_file 存在可读?) then (是)
  :切换到源文件缓冲区
  跳到末尾;
  :逐行追加格式化内容
  保存;
  :提示成功
  清空 g:code2prompt_origin_file;
  stop
else (否)
  :合并内容
  复制到系统剪贴板;
  :提示成功;
  stop
endif

@enduml
